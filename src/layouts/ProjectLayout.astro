---
import BaseLayout from '../components/layout/BaseLayout.astro';
import ProjectBanner from '../components/project/ProjectBanner.astro';
import ProjectMeta from '../components/project/ProjectMeta.astro';
import ProjectNav from '../components/project/ProjectNav.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  entry: CollectionEntry<'projects'>;
  prev?: CollectionEntry<'projects'> | null;
  next?: CollectionEntry<'projects'> | null;
}

const { entry, prev, next } = Astro.props;
const {
  title,
  subtitle,
  year,
  location,
  area,
  collaborators,
  projectType,
  tags,
  bannerImage,
  coverImage,
  description,
} = entry.data;

// Split "中文 · English" into two lines
const titleParts = title.split(' · ');
const titleCN = titleParts[0];
const titleEN = titleParts[1] ?? null;
---

<BaseLayout title={title} description={description}>

  <!-- Header spacer -->
  <div class="h-[72px]"></div>

  <!-- Banner -->
  <ProjectBanner src={bannerImage ?? coverImage} alt={title} />

  <!-- Project header -->
  <div class="max-w-[1200px] mx-auto px-6 md:px-12 mt-12 mb-12">

    <a
      href="/work"
      class="inline-block text-[10px] text-[#aaa] tracking-[0.2em] uppercase hover:text-accent transition-colors duration-200 mb-8"
    >
      ← Work
    </a>

    <h1 class="reveal font-serif font-light leading-[1.1] mb-3">
      <span class="block text-[2.25rem] md:text-[3rem] lg:text-[3.5rem] text-[#1a1a1a]">{titleCN}</span>
      {titleEN && (
        <span class="block text-[1.1rem] md:text-[1.3rem] lg:text-[1.5rem] text-[#aaa] font-light mt-1">{titleEN}</span>
      )}
    </h1>
    <p class="reveal font-serif text-lg md:text-xl text-[#888] italic mb-10 max-w-2xl" data-delay="80">{subtitle}</p>

    <ProjectMeta
      year={year}
      location={location}
      area={area}
      collaborators={collaborators}
      projectType={projectType}
      tags={tags}
    />
  </div>

  <!-- MDX content -->
  <div class="max-w-[1200px] mx-auto px-6 md:px-12 mt-16 pb-8">
    <div class="prose-project">
      <slot />
    </div>
  </div>

  <!-- Prev / Next -->
  <ProjectNav prev={prev} next={next} />


</BaseLayout>

