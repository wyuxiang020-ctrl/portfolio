---
import Header from './Header.astro';
import Footer from './Footer.astro';
import { ClientRouter } from 'astro:transitions';
import '../../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Yuxiang Wang',
  description =
    'Portfolio of Yuxiang Wang — Architecture and Adaptive Reuse researcher at Manchester School of Architecture. Design projects exploring cultural heritage, spatial narrative, and transformation.',
} = Astro.props;

const pageTitle =
  title === 'Yuxiang Wang'
    ? 'Yuxiang Wang — Architecture'
    : `${title} — Yuxiang Wang`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400;1,500&family=Inter:wght@300;400;500&display=swap"
      rel="stylesheet"
    />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <title>{pageTitle}</title>
    <ClientRouter />
  </head>
  <body class="bg-white min-h-screen">
    <!-- Reading progress bar — JS controls opacity + scaleX -->
    <div id="read-progress" aria-hidden="true"></div>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />

    <!-- Back-to-top button -->
    <button id="back-to-top" aria-label="Back to top">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <polyline points="18 15 12 9 6 15"/>
      </svg>
    </button>
  </body>

  <script>
    import PhotoSwipe from 'photoswipe';

    /*
     * All page-level interactivity lives here so it re-runs on every
     * View Transition navigation via astro:page-load.
     *
     * AbortController (_ctrl) carries a signal into every initX() call.
     * When init() fires for a new page it aborts the previous signal,
     * which automatically removes all event listeners from the old page.
     */

    let _ctrl:            AbortController | null = null;
    let _animsDone        = false;   /* guard: prevents double-running animations */
    let _bannerScrollRaf: number | null = null;
    let _glowRaf:         number | null = null;
    let _pswp: InstanceType<typeof PhotoSwipe> | null = null;

    /* ── Scroll reveal ──────────────────────────────────────────── */
    function initReveal() {
      document.documentElement.classList.add('js-reveal');
      const els = document.querySelectorAll<HTMLElement>('.reveal:not(.in)');
      if (!els.length) return;
      const io = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (!entry.isIntersecting) return;
            const el = entry.target as HTMLElement;
            el.style.transitionDelay = (el.dataset.delay ?? '0') + 'ms';
            el.classList.add('in');
            io.unobserve(el);
          });
        },
        { threshold: 0.06, rootMargin: '0px 0px -24px 0px' }
      );
      els.forEach((el) => io.observe(el));
    }

    /* ── Chapter heading line reveal ────────────────────────────── */
    function initHeadingReveal() {
      const headings = document.querySelectorAll<HTMLElement>(
        '.prose-project h2, .prose-project h3'
      );
      if (!headings.length) return;
      const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (reduced) {
        headings.forEach((el) => el.classList.add('heading-revealed'));
        return;
      }
      const io = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (!entry.isIntersecting) return;
            entry.target.classList.add('heading-revealed');
            io.unobserve(entry.target);
          });
        },
        { threshold: 0.2 }
      );
      headings.forEach((el) => io.observe(el));
    }

    /* ── Prose image fade-in ────────────────────────────────────── */
    function initImageFade() {
      document.querySelectorAll<HTMLImageElement>('.prose-project img').forEach((img) => {
        if (img.complete && img.naturalWidth) {
          img.classList.add('img-loaded');
        } else {
          img.classList.add('img-loading');
          img.addEventListener('load', () => {
            img.classList.replace('img-loading', 'img-loaded');
          }, { once: true });
        }
      });
    }

    /* ── Project Banner ─────────────────────────────────────────── */
    function initBanner(signal: AbortSignal) {
      /* Cancel any RAF loops still running from the previous page */
      if (_bannerScrollRaf !== null) { cancelAnimationFrame(_bannerScrollRaf); _bannerScrollRaf = null; }
      if (_glowRaf !== null)         { cancelAnimationFrame(_glowRaf);         _glowRaf         = null; }

      const wrap = document.querySelector<HTMLElement>('.banner-wrap');
      const bg   = document.getElementById('bnr-bg')   as HTMLImageElement | null;
      const main = document.getElementById('bnr-main') as HTMLImageElement | null;
      const glow = document.getElementById('bnr-glow') as HTMLElement | null;
      if (!wrap || !bg || !main || !glow) return;

      const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      /* 1. Entrance zoom: double rAF ensures initial scale(1.07) paints first */
      if (!reduced) {
        requestAnimationFrame(() => {
          requestAnimationFrame(() => {
            if (!signal.aborted) main.classList.add('banner-in');
          });
        });
      } else {
        main.style.scale = '1';
      }

      /* 2. Parallax — 'translate' property is independent of 'scale' */
      if (!reduced) {
        let ticking = false;
        const onScroll = () => {
          const y = window.scrollY;
          main.style.translate = `0 ${(y * 0.22).toFixed(1)}px`;
          bg.style.translate   = `0 ${(y * 0.50).toFixed(1)}px`;
          ticking = false;
          _bannerScrollRaf = null;
        };
        window.addEventListener('scroll', () => {
          if (!ticking) {
            ticking = true;
            _bannerScrollRaf = requestAnimationFrame(onScroll);
          }
        }, { passive: true, signal });
      }

      /* 3. Hover breathing glow — pure JS rAF, no CSS transition conflict */
      if (!reduced) {
        let glowTarget  = 0;
        let glowCurrent = 0;

        const tickGlow = () => {
          if (signal.aborted) { _glowRaf = null; return; }
          const pulse = 0.13 + 0.07 * Math.sin(Date.now() / 413);
          glowCurrent = glowTarget > 0
            ? Math.min(glowCurrent + 0.012, pulse)
            : Math.max(glowCurrent - 0.006, 0);
          glow.style.opacity = glowCurrent.toFixed(3);
          _glowRaf = (glowCurrent > 0.001 || glowTarget > 0)
            ? requestAnimationFrame(tickGlow)
            : null;
        };

        wrap.addEventListener('mouseenter', () => {
          glowTarget = 1;
          if (_glowRaf === null) _glowRaf = requestAnimationFrame(tickGlow);
        }, { signal });
        wrap.addEventListener('mouseleave', () => { glowTarget = 0; }, { signal });
      }
    }

    /* ── Lightbox — PhotoSwipe v5 ──────────────────────────────── */
    function initLightbox(signal: AbortSignal) {
      const imgs = Array.from(
        document.querySelectorAll<HTMLImageElement>('.prose-project img')
      );
      if (!imgs.length) return;

      /* openAt receives the actual element (not just a src string) so the
         index lookup is identity-based and immune to URL normalisation.
         It is async so we can await decode() and get correct naturalWidth/Height
         before handing dimensions to PhotoSwipe.                              */
      const openAt = async (target: HTMLImageElement) => {
        if (_pswp) { _pswp.destroy(); _pswp = null; }

        /* Wait for the clicked image to decode so naturalWidth/Height are
           correct. Without this, a lazily-loaded image gives 0×0 and PhotoSwipe
           falls back to 1400×900, miscalculating zoom and image position.     */
        if (!target.complete || !target.naturalWidth) {
          try { await target.decode(); } catch { /* network or decode error — proceed anyway */ }
        }

        /* Snapshot scroll — focus-restore on close causes the page to jump */
        const savedScrollY = window.scrollY;

        /* Re-query at click time so View Transition navigations never leave
           a stale image list — stale lists break arrow nav and the counter. */
        const liveImgs = Array.from(
          document.querySelectorAll<HTMLImageElement>('.prose-project img')
        );

        /* Identity comparison — robust even when src URLs differ by trailing
           slash, query string, or protocol normalisation.                     */
        const startIndex = Math.max(0, liveImgs.indexOf(target));

        const pswp = new PhotoSwipe({
          dataSource: liveImgs.map((img) => ({
            src:    img.src,
            /* Prefer naturalWidth after load; fall back to rendered size;
               final fallback keeps PhotoSwipe from crashing on 0×0.         */
            width:  img.naturalWidth  || img.offsetWidth  || 1400,
            height: img.naturalHeight || img.offsetHeight || 900,
            alt:    img.alt || '',
          })),
          index:              startIndex,
          bgOpacity:          0.93,
          maxZoomLevel:       4,
          initialZoomLevel:   'fit',
          secondaryZoomLevel: 2,          /* single-click / tap zoom target */
          imageClickAction:   'zoom',     /* click toggles fit ↔ secondary  */
          tapAction:          'zoom',
          doubleTapAction:    'zoom',
          allowPanToNext:     false,      /* don't swipe slides while panning */
        });

        /* ── Restore scroll position when lightbox closes ───────── */
        pswp.on('destroy', () => {
          _pswp = null;
          /* Use instant to override html { scroll-behavior: smooth }   */
          window.scrollTo({ top: savedScrollY, behavior: 'instant' });
        });

        /* ── Wheel-to-zoom anchored at cursor ───────────────────── */
        /* Multiplicative zoom (×1.15 per tick) preserves proportions */
        /* duration = 0 avoids stacking multiple in-flight animations  */
        pswp.on('bindEvents', () => {
          const root = pswp.element as HTMLElement | null;
          if (!root) return;
          root.addEventListener('wheel', (e: WheelEvent) => {
            e.preventDefault();
            const slide = pswp.currSlide as any;
            if (!slide) return;
            const initZ  = slide.zoomLevels.initial as number;
            const curr   = slide.currentResolution  as number;
            const factor = e.deltaY < 0 ? 1.15 : 1 / 1.15;
            const next   = Math.min(Math.max(curr * factor, initZ), initZ * 4);
            if (Math.abs(next - curr) < 0.001) return;
            const r = root.getBoundingClientRect();
            slide.zoomTo(next, { x: e.clientX - r.left, y: e.clientY - r.top }, 0);
          }, { passive: false });
        });

        pswp.init();
        _pswp = pswp;
      };

      imgs.forEach((img) => {
        img.addEventListener('click', () => openAt(img), { signal });
      });
    }

    /* ── Reading progress bar ──────────────────────────────────── */
    function initReadProgress(signal: AbortSignal) {
      const bar = document.getElementById('read-progress') as HTMLElement | null;
      if (!bar) return;

      /* Only visible on project detail pages */
      if (!document.querySelector('.prose-project')) {
        bar.classList.remove('rp-visible');
        bar.style.transform = 'scaleX(0)';
        return;
      }

      const update = () => {
        const scrollY  = window.scrollY;
        const totalH   = document.documentElement.scrollHeight - window.innerHeight;
        const progress = totalH > 0 ? Math.min(scrollY / totalH, 1) : 0;

        bar.style.transform = `scaleX(${progress.toFixed(4)})`;

        /* Fade in only after the reader has scrolled a bit */
        if (scrollY > 100) {
          bar.classList.add('rp-visible');
        } else {
          bar.classList.remove('rp-visible');
        }
      };

      window.addEventListener('scroll', update, { passive: true, signal });
      update(); /* set initial state */
    }

    /* ── Back-to-top button ─────────────────────────────────────── */
    function initBackToTop(signal: AbortSignal) {
      const btn = document.getElementById('back-to-top') as HTMLButtonElement | null;
      if (!btn) return;

      const onScroll = () => {
        btn.classList.toggle('btt-visible', window.scrollY > 300);
      };

      btn.addEventListener('click', () => {
        window.scrollTo({ top: 0, behavior: 'smooth' });
      }, { signal });

      window.addEventListener('scroll', onScroll, { passive: true, signal });
      onScroll(); /* set initial visibility */
    }

    /* ── Lifecycle ──────────────────────────────────────────────────
     *
     * The root cause of the SPA-navigation bug was timing:
     *
     *   astro:page-load  fires AFTER the View Transition animation ends.
     *   astro:after-swap fires AFTER the body swap but BEFORE the animation.
     *
     * When the user navigated home → project, the new DOM (including
     * .prose-project img elements) existed immediately after the swap, but
     * click handlers weren't registered until page-load — leaving a window
     * where clicking did nothing, and PhotoSwipe could open with stale state
     * from the previous page's AbortController.
     *
     * Fix: register lightbox click handlers in astro:after-swap (as early as
     * possible), and run reveal / banner animations in astro:page-load (after
     * the transition, so they aren't interrupted by it).
     */

    document.addEventListener('astro:after-swap', () => {
      /* New DOM is in place. CSS from the persistent <head> stylesheet is
         already applied. Register click handlers immediately.              */
      _animsDone = false;
      _pswp?.destroy();
      _ctrl?.abort();
      _ctrl = new AbortController();
      initLightbox(_ctrl.signal);
      initReadProgress(_ctrl.signal);
      initBackToTop(_ctrl.signal);
    });

    document.addEventListener('astro:page-load', () => {
      /* Lightbox + progress + back-to-top: init here only on hard-refresh /
         no-VT fallback (astro:after-swap didn't fire, so _ctrl is null).  */
      if (!_ctrl) {
        _ctrl = new AbortController();
        initLightbox(_ctrl.signal);
        initReadProgress(_ctrl.signal);
        initBackToTop(_ctrl.signal);
      }
      /* Animations: run once per page — guard prevents double-run when
         both astro:page-load and the direct call below execute.         */
      if (!_animsDone) {
        _animsDone = true;
        initReveal();
        initHeadingReveal();
        initImageFade();
        initBanner(_ctrl.signal);
      }
    });

    /* Hard-refresh / initial load guard ────────────────────────────
     * astro:page-load may fire before this <script> module executes.
     * If it already ran the guards above are no-ops; otherwise we
     * bootstrap here so the initial page is never left un-initialised. */
    if (!_ctrl) {
      _ctrl = new AbortController();
      initLightbox(_ctrl.signal);
      initReadProgress(_ctrl.signal);
      initBackToTop(_ctrl.signal);
    }
    if (!_animsDone) {
      _animsDone = true;
      initReveal();
      initHeadingReveal();
      initImageFade();
      initBanner(_ctrl.signal);
    }
  </script>
</html>
