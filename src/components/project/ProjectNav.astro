---
import type { CollectionEntry } from 'astro:content';

interface Props {
  prev?: CollectionEntry<'projects'> | null;
  next?: CollectionEntry<'projects'> | null;
}
const { prev, next } = Astro.props;
---

<nav aria-label="Project navigation" class="border-t border-[#e5e5e5] mt-28 pt-14">
  <div class="max-w-[1200px] mx-auto px-6 md:px-12">

    <div class="grid grid-cols-2 gap-8 mb-12">

      <!-- Prev -->
      <div>
        {prev && (
          <a href={`/work/${prev.id}`} class="group block">
            <p class="text-[10px] text-[#aaa] tracking-[0.2em] uppercase mb-3">← Previous</p>
            <h4 class="font-serif text-xl text-[#1a1a1a] leading-snug group-hover:text-accent transition-colors duration-200">
              {prev.data.title}
            </h4>
            <p class="text-xs text-[#999] mt-1">{prev.data.year} · {prev.data.location}</p>
          </a>
        )}
      </div>

      <!-- Next -->
      <div class="text-right">
        {next && (
          <a href={`/work/${next.id}`} class="group block">
            <p class="text-[10px] text-[#aaa] tracking-[0.2em] uppercase mb-3">Next →</p>
            <h4 class="font-serif text-xl text-[#1a1a1a] leading-snug group-hover:text-accent transition-colors duration-200">
              {next.data.title}
            </h4>
            <p class="text-xs text-[#999] mt-1">{next.data.year} · {next.data.location}</p>
          </a>
        )}
      </div>

    </div>

    <div class="text-center">
      <a
        href="/work"
        class="text-[11px] tracking-[0.2em] uppercase text-[#999] hover:text-accent transition-colors duration-200"
      >
        All Projects
      </a>
    </div>

  </div>
</nav>
