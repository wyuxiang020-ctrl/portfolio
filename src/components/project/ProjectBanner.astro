---
interface Props {
  src: string;
  alt: string;
}
const { src, alt } = Astro.props;
---

<div class="banner-wrap">

  <!-- Blurred ambient background (same image, covers letterbox) -->
  <img
    id="bnr-bg"
    class="banner-bg"
    src={src}
    alt=""
    aria-hidden="true"
    loading="eager"
    fetchpriority="high"
  />

  <!-- Light darkening overlay -->
  <div class="banner-overlay"></div>

  <!-- Parallax wrapper (JS moves this) -->
  <div id="bnr-outer" class="banner-outer">
    <!-- Main image: entrance zoom via CSS transition -->
    <img
      id="bnr-main"
      class="banner-main"
      src={src}
      alt={alt}
      loading="eager"
      fetchpriority="high"
    />
  </div>

  <!-- Bottom gradient fade to white -->
  <div class="banner-fade"></div>

</div>

<script is:inline>
  (function () {
    var bg    = document.getElementById('bnr-bg');
    var outer = document.getElementById('bnr-outer');
    var main  = document.getElementById('bnr-main');
    if (!main || !bg || !outer) return;

    var reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    /* ── Entrance animation ────────────────────────────────────
       CSS has .banner-main { transform: scale(1.07) } initially.
       We add .banner-in after two rAF frames so the browser paints
       the 1.07 state first, then transitions to scale(1.0).
       Double rAF = guaranteed one paint frame between set and transition.
    ────────────────────────────────────────────────────────── */
    if (!reduced) {
      requestAnimationFrame(function () {
        requestAnimationFrame(function () {
          main.classList.add('banner-in');
        });
      });
    } else {
      main.classList.add('banner-in'); /* skip animation immediately */
    }

    /* ── Parallax ──────────────────────────────────────────────
       CORRECT direction: positive translateY pushes content DOWN,
       which counteracts the natural upward scroll → content appears
       to scroll slower (linger effect).

       outer (main image): +scrollY * 0.22 → moves slower than page
       bg (blurred):       +scrollY * 0.48 → moves even slower → depth
    ────────────────────────────────────────────────────────── */
    if (!reduced) {
      var ticking = false;

      function onScroll() {
        var y = window.scrollY;
        outer.style.transform = 'translateY(' + (y * 0.22).toFixed(1) + 'px)';
        bg.style.transform    = 'translateY(' + (y * 0.48).toFixed(1) + 'px)';
        ticking = false;
      }

      window.addEventListener('scroll', function () {
        if (!ticking) {
          ticking = true;
          requestAnimationFrame(onScroll);
        }
      }, { passive: true });
    }
  })();
</script>
