---
interface Props {
  src: string;
  alt: string;
}
const { src, alt } = Astro.props;
---

<div class="banner-wrap">

  <!-- Blurred ambient background (same image, fills letterbox) -->
  <img
    id="bnr-bg"
    class="banner-bg"
    src={src}
    alt=""
    aria-hidden="true"
    loading="eager"
    fetchpriority="high"
  />

  <!-- Light darkening overlay -->
  <div class="banner-overlay"></div>

  <!-- Main image: entrance zoom via CSS 'scale' transition -->
  <img
    id="bnr-main"
    class="banner-main"
    src={src}
    alt={alt}
    loading="eager"
    fetchpriority="high"
  />

  <!-- Hover breathing glow (opacity driven by JS rAF) -->
  <div id="bnr-glow"></div>

  <!-- Bottom gradient fade to white -->
  <div class="banner-fade"></div>

  <!-- View Full Image — solo lightbox trigger -->
  <div class="bnr-zoom-wrap">
    <span class="bnr-zoom-label">View Full Image</span>
    <button
      id="bnr-zoom-btn"
      class="bnr-zoom-btn"
      aria-label="View full image"
      data-src={src}
    >
      <!-- Lucide Maximize2: expand arrows -->
      <svg xmlns="http://www.w3.org/2000/svg" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M15 3h6v6M9 21H3v-6M21 3l-7 7M3 21l7-7"/>
      </svg>
    </button>
  </div>

</div>
