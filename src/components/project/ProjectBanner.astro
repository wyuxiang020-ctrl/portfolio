---
interface Props {
  src: string;
  alt: string;
}
const { src, alt } = Astro.props;
---

<div class="banner-wrap">

  <!-- Blurred ambient background (same image, fills letterbox) -->
  <img
    id="bnr-bg"
    class="banner-bg"
    src={src}
    alt=""
    aria-hidden="true"
    loading="eager"
    fetchpriority="high"
  />

  <!-- Light darkening overlay -->
  <div class="banner-overlay"></div>

  <!-- Main image: entrance zoom via CSS 'scale' transition -->
  <img
    id="bnr-main"
    class="banner-main"
    src={src}
    alt={alt}
    loading="eager"
    fetchpriority="high"
  />

  <!-- Hover breathing glow (opacity driven by JS rAF) -->
  <div id="bnr-glow"></div>

  <!-- Bottom gradient fade to white -->
  <div class="banner-fade"></div>

</div>

<script is:inline>
(function () {
  var wrap = document.querySelector('.banner-wrap');
  var bg   = document.getElementById('bnr-bg');
  var main = document.getElementById('bnr-main');
  var glow = document.getElementById('bnr-glow');
  if (!main || !bg || !glow || !wrap) return;

  var reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  /* ── 1. Entrance animation ─────────────────────────────────────
     CSS starts at  scale: 1.07  (defined in global.css)
     We add .banner-in (scale: 1.0) after TWO rAF frames so the
     browser definitely paints the enlarged state first, then
     the CSS transition runs visibly.
  ─────────────────────────────────────────────────────────────── */
  if (!reduced) {
    requestAnimationFrame(function () {
      requestAnimationFrame(function () {
        main.classList.add('banner-in');
      });
    });
  } else {
    main.style.scale = '1';  /* skip instantly */
  }

  /* ── 2. Parallax ───────────────────────────────────────────────
     Uses the CSS Level 2 'translate' property (independent of
     'scale'), so the entrance CSS transition on 'scale' is never
     overwritten.

     Positive Y value pushes element DOWN, countering the natural
     upward scroll → element appears to scroll UP slower (linger).

     main: +0.22× scrollY  (subtle linger on main image)
     bg:   +0.50× scrollY  (more linger = stronger depth illusion)
  ─────────────────────────────────────────────────────────────── */
  if (!reduced) {
    var ticking = false;
    function onScroll() {
      var y = window.scrollY;
      main.style.translate = '0 ' + (y * 0.22).toFixed(1) + 'px';
      bg.style.translate   = '0 ' + (y * 0.50).toFixed(1) + 'px';
      ticking = false;
    }
    window.addEventListener('scroll', function () {
      if (!ticking) { ticking = true; requestAnimationFrame(onScroll); }
    }, { passive: true });
  }

  /* ── 3. Hover breathing glow (JS rAF — avoids CSS transition / ─
     animation conflict on the same property)

     On mouseenter: glowTarget → 1, opacity ramps up + breathes
     On mouseleave: glowTarget → 0, opacity fades out
  ─────────────────────────────────────────────────────────────── */
  if (!reduced) {
    var glowTarget  = 0;
    var glowCurrent = 0;
    var glowRunning = false;

    function tickGlow() {
      /* breathing: oscillates ~0.06 – 0.20 with a ~2.6 s period */
      var pulse = 0.13 + 0.07 * Math.sin(Date.now() / 413);

      if (glowTarget > 0) {
        glowCurrent = Math.min(glowCurrent + 0.012, pulse);
      } else {
        glowCurrent = Math.max(glowCurrent - 0.006, 0);
      }

      glow.style.opacity = glowCurrent.toFixed(3);

      if (glowCurrent > 0.001 || glowTarget > 0) {
        requestAnimationFrame(tickGlow);
      } else {
        glowRunning = false;
      }
    }

    wrap.addEventListener('mouseenter', function () {
      glowTarget = 1;
      if (!glowRunning) { glowRunning = true; requestAnimationFrame(tickGlow); }
    });
    wrap.addEventListener('mouseleave', function () {
      glowTarget = 0;
    });
  }
})();
</script>
