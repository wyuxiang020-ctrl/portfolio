---
interface Props {
  src: string;
  alt: string;
}
const { src, alt } = Astro.props;
---

<!-- Black letterbox container — image shows in full, no cropping -->
<div class="w-full bg-black flex items-center justify-center" style="height: 68vh; max-height: 820px;">
  <img
    src={src}
    alt={alt}
    style="width: 100%; height: 100%; object-fit: contain; object-position: center; display: block;"
    loading="eager"
    fetchpriority="high"
  />
</div>
