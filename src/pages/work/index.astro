---
import BaseLayout from '../../components/layout/BaseLayout.astro';
import ProjectCard from '../../components/work/ProjectCard.astro';
import { getCollection } from 'astro:content';

const projects = await getCollection('projects');
const sorted = projects.sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout title="Work" description="Selected architecture projects by Yuxiang Wang, 2023–present.">

  <div class="h-[72px]"></div>

  <section class="py-16 md:py-24">
    <div class="max-w-[1200px] mx-auto px-6 md:px-12">

      <!-- Page header -->
      <div class="mb-20 md:mb-28 max-w-xl">
        <h1 class="reveal font-serif text-[3.5rem] md:text-[5rem] text-[#1a1a1a] font-light leading-none mb-6">
          Work
        </h1>
        <p class="reveal text-[#777] text-base leading-relaxed" data-delay="80">
          Selected projects, 2023 – present. Academic research, live briefs, and design
          explorations across adaptive reuse, heritage, and community architecture.
        </p>
      </div>

      <!-- Project grid: 2 columns -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-x-14 gap-y-24">
        {sorted.map((project) => <ProjectCard project={project} />)}
      </div>

    </div>
  </section>

</BaseLayout>
