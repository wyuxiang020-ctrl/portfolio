---
import BaseLayout from '../components/layout/BaseLayout.astro';

const social = [
  { platform: '小红书',   handle: '@yuxiangwang',  href: '#' },
  { platform: 'Instagram', handle: '@yuxiang.arch', href: '#' },
  { platform: 'Behance',   handle: 'Yuxiang Wang',  href: '#' },
];
---

<BaseLayout
  title="Contact"
  description="Get in touch with Yuxiang Wang — architecture, collaboration, and conversation."
>

  <div class="h-[72px]"></div>

  <section class="py-16 md:py-24">
    <div class="max-w-[1200px] mx-auto px-6 md:px-12">

      <div class="max-w-2xl">

        <!-- Title -->
        <h1 class="font-serif text-[3.5rem] md:text-[5rem] text-[#1a1a1a] font-light leading-none mb-12">
          Contact
        </h1>

        <!-- Lead -->
        <p class="font-serif text-xl md:text-2xl text-[#1a1a1a] leading-[1.6] mb-20">
          如果你对我的工作感兴趣，或想合作 / 交流，欢迎联系。
        </p>

        <!-- Contact details -->
        <div class="space-y-14">

          <!-- Email -->
          <div>
            <p class="text-[10px] text-[#aaa] tracking-[0.25em] uppercase mb-4">Email</p>
            <a
              href="mailto:m17347819733@163.com"
              class="font-serif text-[1.75rem] md:text-[2.25rem] text-[#1a1a1a] hover:text-accent transition-colors duration-200 leading-none"
            >
              m17347819733@163.com
            </a>
          </div>

          <!-- Phone -->
          <div>
            <p class="text-[10px] text-[#aaa] tracking-[0.25em] uppercase mb-4">Phone / WeChat</p>
            <a
              href="tel:+8617347819733"
              class="font-serif text-[1.75rem] md:text-[2.25rem] text-[#1a1a1a] hover:text-accent transition-colors duration-200 leading-none"
            >
              +86 173-4781-9733
            </a>
          </div>

          <!-- Social -->
          <div>
            <p class="text-[10px] text-[#aaa] tracking-[0.25em] uppercase mb-6">Social</p>
            <ul class="flex flex-col gap-4 list-none m-0 p-0">
              {social.map(({ platform, handle, href }) => (
                <li>
                  <a href={href} class="group flex items-baseline gap-5">
                    <span class="text-[10px] tracking-[0.18em] uppercase text-[#aaa] w-28 shrink-0">
                      {platform}
                    </span>
                    <span class="text-[#1a1a1a] group-hover:text-accent transition-colors duration-200 text-sm">
                      {handle}
                    </span>
                  </a>
                </li>
              ))}
            </ul>
          </div>

        </div>
      </div>
    </div>
  </section>

</BaseLayout>
